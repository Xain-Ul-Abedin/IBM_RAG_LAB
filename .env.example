# --- IBM watsonx.ai Credentials ---
# Follow Task 1-3 in README.md to obtain these
WATSONX_APIKEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Replicate Credentials (Alternative) ---
# Follow instructions in README.md to get a Replicate token
REPLICATE_API_TOKEN=your_replicate_api_token_here

# --- Ollama (Local & Free) ---
# No API key required. Make sure Ollama desktop app is running.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b # or granite-code:8b, granite3-dense:8b, etc.
